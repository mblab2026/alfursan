# ==========================================================================
#  .env.example  —  TEMPLATE ONLY. Never put real secrets in this file.
#  Copy it to .env   ->   cp .env.example .env
#  Put the REAL key/password in .env (gitignored). NOT here.
# ==========================================================================

# seats.aero Pro API key. REAL value goes in .env, NOT here.
SEATS_API_KEY=pro_xxxxxxxxxxxxxxxxxxxxx

# AlFursan program slug on seats.aero. If results come back empty, change this first.
SEATS_SOURCE=saudia

# Only pull flights originating in this region (keeps API usage low). Empty = all regions.
ORIGIN_REGION=Asia

# Departure airports to show. Leave EMPTY to show EVERY Saudi city with award flights.
# (Comma-separated IATA codes to restrict, e.g. ORIGINS=RUH,JED)
ORIGINS=

# How often to refresh data from seats.aero (hours)
REFRESH_HOURS=6

# Password gating the manual /api/refresh endpoint. REAL value goes in .env, NOT here.
# Leave EMPTY here. Empty in .env disables /api/refresh (returns 403).
REFRESH_PASSWORD=
